# Live PDF/text import in the sandbox (app/api/extract -> Ollama Cloud).
#
# Without OLLAMA_API_KEY the /api/extract route returns 503 NOT_CONFIGURED and the demo
# falls back to a deterministic sample extraction — so the demo still works with no key.
# Copy this file to .env.local and fill in OLLAMA_API_KEY to enable the live model.

# Ollama Cloud API key — SERVER-ONLY (never exposed to the browser bundle).
OLLAMA_API_KEY=

# Model id available on the Ollama Cloud endpoint.
OLLAMA_MODEL=llama3.2:3b

# OpenAI-compatible base URL for Ollama Cloud.
OLLAMA_BASE_URL=https://ollama.com/v1

# Per-request timeout in milliseconds. (A non-numeric value falls back to 30000.)
OLLAMA_TIMEOUT_MS=30000

# --- Abuse guards for a public deployment (optional) ---
# Extra allowed origins for /api/extract (comma-separated). Same-origin is always allowed.
ALLOWED_ORIGINS=
# Per-IP request cap and window for /api/extract.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# --- Beta recruitment (marketing site) ---
# TestFlight public join URL. Unset/empty → the /beta page runs Phase A (email intake).
# Set it the moment a build clears Beta App Review → Phase B (the gold TestFlight button).
NEXT_PUBLIC_TESTFLIGHT_URL=

# Firebase Admin credentials — RESERVED for the Firestore-swap follow-up PR
# (docs/features/case-file-redesign/01 §7 Phasing). The beta action is a validated
# stub until these exist; nothing reads them yet. SERVER-ONLY when they land.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# --- Address autocomplete ---
# Mapbox PUBLIC access token (pk.*) for street-address autocomplete on the New Case / New Location /
# Submission screens. PUBLIC by design — it ships in the client bundle (NEXT_PUBLIC_*); restrict it
# by URL in the Mapbox dashboard. Without it, the street fields degrade to plain text inputs.
NEXT_PUBLIC_MAPBOX_TOKEN=
